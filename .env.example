# ─── Supabase (optional — curated gallery + upload registry) ─────────────────
# Project: wedding-photo-uploader
# Dashboard → Project Settings → API
SUPABASE_URL=https://rnbjtgmzddgtthfbdzsa.supabase.co

# Publishable key (public, safe for client — labeled "Publishable" in Supabase dashboard)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret — server only, never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Legacy anon JWT key still works if publishable key is not set:
# SUPABASE_ANON_KEY=eyJ...
