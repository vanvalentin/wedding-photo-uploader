# ─── Google Drive ───────────────────────────────────────────────────────────
# ID of the target folder (from the folder URL: drive.google.com/drive/folders/<ID>)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ─── Auth: OAuth (RECOMMENDED for personal Google Drive / Gmail) ─────────────
# Service accounts have NO storage on personal Drive — use OAuth instead.
# Run: node scripts/get-refresh-token.mjs  (see README)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token

# ─── Auth: Service Account (Google Workspace Shared Drives ONLY) ────────────
# Do NOT use for personal Gmail/Drive — uploads will fail with 403 storageQuotaExceeded.
# GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated origins allowed for CORS (defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# ─── Client (Vite) — local dev only ──────────────────────────────────────────
# Leave empty on Vercel (same-origin /api). For local dev, leave empty to use Vite proxy.
VITE_API_URL=
