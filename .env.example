# ─── Storage provider ────────────────────────────────────────────────────────
# Use "r2" for Cloudflare R2 uploads, or "google_drive" to keep the legacy Drive flow.
STORAGE_PROVIDER=r2

# ─── Cloudflare R2 (recommended for ~10GB+ website media) ────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
# Presigned upload URL lifetime in seconds.
R2_UPLOAD_URL_EXPIRES_IN_SECONDS=900

# ─── Google Drive mirror / legacy fallback (Shared Drive + service account) ──
# Folder must be inside a Google Workspace Shared Drive (not personal My Drive).
# R2 uploads are mirrored browser-direct to this folder; legacy Drive mode uses
# the same credentials as its primary upload destination.
GOOGLE_DRIVE_FOLDER_ID=your_shared_drive_folder_id

GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Client (Vite) — local dev only ──────────────────────────────────────────
# Leave empty on Vercel (same-origin /api).
VITE_API_URL=

# ─── Supabase (optional — curated gallery + upload registry) ─────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# ─── Admin (optional — curate highlights at /admin) ──────────────────────────
ADMIN_SECRET=choose-a-long-random-password
